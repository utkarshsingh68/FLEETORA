NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-project-key
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# NestJS API (configure these on Render, never commit private keys)
PORT=4000
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-project-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CORS_ORIGIN=http://localhost:3000
CUSTOMER_PORTAL_REDIRECT_URL=http://localhost:3000/customer-portal
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_independent_webhook_secret

# Scheduled-report worker (private server environment only)
REPORT_STORAGE_BUCKET=fleetora-reports
REPORT_WORKER_POLL_MS=60000
REPORT_WORKER_BATCH_SIZE=5
REPORT_WORKER_LEASE_MS=900000
REPORT_SIGNED_URL_TTL_SECONDS=604800
REPORT_REQUEST_TIMEOUT_MS=120000
REPORT_MAX_ROWS=50000
REPORT_MAX_PDF_ROWS=10000
REPORT_WORKER_RUN_ONCE=false
RESEND_API_KEY=
REPORT_FROM_EMAIL=Fleetora Reports <reports@your-verified-domain.com>
